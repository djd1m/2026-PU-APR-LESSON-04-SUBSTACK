# Database
DATABASE_URL=postgresql://postgres:password@localhost:5436/substackru
POSTGRES_DB=substackru
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6380

# App
NODE_ENV=development
APP_URL=http://localhost:3010
APP_PORT=3000
JWT_SECRET=changeme-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=changeme-refresh-secret-at-least-32-chars

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Payments — CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=pk_xxxxxxxxxxxxxxx
CLOUDPAYMENTS_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
CLOUDPAYMENTS_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Payments — YooKassa (fallback)
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
YOOKASSA_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Payments — SBP
SBP_MERCHANT_ID=xxxxxxxxxxxxxxxx
SBP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=http://localhost:9010
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=substackru

# Platform
PLATFORM_FEE_PERCENT=10
MINIMUM_PAYOUT_KOPECKS=100000
